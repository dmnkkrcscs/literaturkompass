// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum CompType {
  WETTBEWERB
  ANTHOLOGIE
  ZEITSCHRIFT
}

enum CompStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum SubStatus {
  PLANNED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum SourceType {
  AGGREGATOR
  SEARCH
  MANUAL
}

enum CrawlStatus {
  SUCCESS
  FAILED
  DUPLICATE
  IRRELEVANT
}

enum AnalysisType {
  EXTRACTION
  RELEVANCE
  RECOMMENDATION
  TEXT_ANALYSIS
}

enum FeedbackAction {
  DISMISSED
  STARRED
  REPORTED
  SUBMITTED
}

// ============================================================================
// MODELS
// ============================================================================

model Competition {
  id                  String            @id @default(cuid())
  legacyId            String?           @unique // For migration from v1 JSON IDs like "nature-writing-2026"

  type                CompType
  name                String
  organizer           String?
  deadline            DateTime?

  theme               String?
  genres              String[]          @default([])
  prize               String?
  maxLength           String?

  requirements        String?
  ageRestriction      String?
  regionRestriction   String?
  fee                 String?

  url                 String            @unique
  description         String?

  sourceId            String
  source              Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  relevanceScore      Float?
  aiExtracted         Boolean           @default(false)
  aiConfidence        Float?
  rawText             String?           // Stored for re-processing

  status              CompStatus        @default(ACTIVE)
  dismissed           Boolean           @default(false)
  starred             Boolean           @default(false)
  starredAt           DateTime?

  magazineId          String?
  magazine            Magazine?         @relation(fields: [magazineId], references: [id], onDelete: SetNull)

  submissions         Submission[]
  analyses            AiAnalysis[]
  crawlLogs           CrawlLog[]
  feedback            UserFeedback[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Indexes for common queries
  @@index([status, dismissed])
  @@index([status, dismissed, deadline])
  @@index([type])
  @@index([starred])
  @@index([magazineId])
}

model Source {
  id                  String            @id @default(cuid())
  name                String
  url                 String            @unique
  type                SourceType

  adapter             String?           // JSON config for CSS selectors

  lastCrawl           DateTime?
  successRate         Float             @default(0)
  totalCrawls         Int               @default(0)
  isActive            Boolean           @default(true)

  competitions        Competition[]
  crawlLogs           CrawlLog[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Submission {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  status              SubStatus         @default(PLANNED)

  title               String?           // Titel des eingereichten Textes
  publishedUrl        String?           // Link zur Veröffentlichung (Hall of Fame)
  textContent         String?           // Eingereichten Text (für KI-Stilanalyse)

  documentUrl         String?
  documentName        String?

  submittedAt         DateTime?
  responseAt          DateTime?

  notes               String?

  charCount           Int?
  wordCount           Int?
  genreMatch          Float?
  styleScore          Float?

  requirementsMet     Json?             // Stores validation results as JSON

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Indexes for common queries
  @@index([status])
  @@index([competitionId, status])
  @@index([createdAt])
}

model AiAnalysis {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  type                AnalysisType
  prompt              String
  response            Json

  model               String
  tokensUsed          Int
  costCents           Float

  createdAt           DateTime          @default(now())
}

model CrawlLog {
  id                  String            @id @default(cuid())
  sourceId            String
  source              Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  competitionId       String?
  competition         Competition?      @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  url                 String
  status              CrawlStatus

  httpCode            Int?
  errorMessage        String?
  extractedData       Json?

  processingMs        Int?

  createdAt           DateTime          @default(now())

  // Indexes for common queries
  @@index([sourceId, createdAt])
  @@index([url])
  @@index([status, createdAt])
}

model UserFeedback {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  action              FeedbackAction
  reason              String?

  createdAt           DateTime          @default(now())

  // Index for common queries
  @@index([competitionId])
}

model Magazine {
  id            String        @id @default(cuid())
  name          String
  url           String        @unique
  location      String?
  description   String?
  genres        String[]      @default([])
  requirements  String?
  isActive      Boolean       @default(true)

  issues        Competition[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ============================================================================
// AI LEARNING & NOTIFICATIONS
// ============================================================================

model DismissalPattern {
  id        String   @id @default(cuid())
  pattern   String   @unique // Kategorie (z.B. "falsches_genre", "zu_teuer")
  keywords  String[] @default([])
  count     Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Verlage/Veranstalter, die der User wiederholt wegen schlechter Qualität /
// Unseriösität abgelehnt hat. Schlüssel ist die normalisierte URL-Domain
// (z.B. "verlag-xy.de"). Ab `BLOCK_THRESHOLD` Dismissals (siehe Code) wird
// `blocked = true` gesetzt — neue Wettbewerbe dieser Domain werden dann
// beim Crawl direkt mit dismissed=true angelegt, tauchen also nicht in der
// Triage auf.
model BlockedPublisher {
  id              String    @id @default(cuid())
  domain          String    @unique
  organizer       String?
  dismissalCount  Int       @default(1)
  blocked         Boolean   @default(false)
  blockedAt       DateTime?
  lastReason      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([blocked])
}

// Singleton-Profil des Users. Steuert Auto-Dismiss-Logik im Crawler:
// * `allowedRegions` — Liste von Region-Keywords, mit denen die `regionRestriction`
//   eines Wettbewerbs verglichen wird. Wenn die Restriction nicht-leer ist und KEINEN
//   dieser Keywords (case-insensitive Substring) enthält → automatisch dismissed.
// * `age` — wird zusätzlich in die KI-Triage-Bewertung gegeben (Alter passt / passt nicht).
model UserProfile {
  id              String    @id @default(cuid())
  age             Int?
  allowedRegions  String[]  @default([])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model NotificationLog {
  id            String   @id @default(cuid())
  competitionId String?
  type          String   // "new_competition" | "deadline_reminder" | "daily_digest"
  message       String

  sentAt        DateTime @default(now())

  @@index([type, sentAt])
}

// ============================================================================
// NextAuth.js / Auth.js v5 MODELS
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
