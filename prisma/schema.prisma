// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum CompType {
  WETTBEWERB
  ANTHOLOGIE
  ZEITSCHRIFT
}

enum CompStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum SubStatus {
  PLANNED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum SourceType {
  AGGREGATOR
  SEARCH
  MANUAL
}

enum CrawlStatus {
  SUCCESS
  FAILED
  DUPLICATE
  IRRELEVANT
}

enum AnalysisType {
  EXTRACTION
  RELEVANCE
  RECOMMENDATION
  TEXT_ANALYSIS
}

enum FeedbackAction {
  DISMISSED
  STARRED
  REPORTED
  SUBMITTED
}

// ============================================================================
// MODELS
// ============================================================================

model Competition {
  id                  String            @id @default(cuid())
  legacyId            String?           @unique // For migration from v1 JSON IDs like "nature-writing-2026"

  type                CompType
  name                String
  organizer           String?
  deadline            DateTime?

  theme               String?
  genres              String[]          @default([])
  prize               String?
  maxLength           String?

  requirements        String?
  ageRestriction      String?
  regionRestriction   String?
  fee                 String?

  url                 String            @unique
  description         String?

  sourceId            String
  source              Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  relevanceScore      Float?
  aiExtracted         Boolean           @default(false)
  aiConfidence        Float?
  rawText             String?           // Stored for re-processing

  status              CompStatus        @default(ACTIVE)
  dismissed           Boolean           @default(false)
  starred             Boolean           @default(false)
  starredAt           DateTime?

  submissions         Submission[]
  analyses            AiAnalysis[]
  crawlLogs           CrawlLog[]
  feedback            UserFeedback[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Indexes for common queries
  @@index([type])
  @@index([deadline])
  @@index([status])
  @@index([starred])
  @@index([dismissed])
}

model Source {
  id                  String            @id @default(cuid())
  name                String
  url                 String            @unique
  type                SourceType

  adapter             String?           // JSON config for CSS selectors

  lastCrawl           DateTime?
  successRate         Float             @default(0)
  totalCrawls         Int               @default(0)
  isActive            Boolean           @default(true)

  competitions        Competition[]
  crawlLogs           CrawlLog[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Submission {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  status              SubStatus         @default(PLANNED)

  documentUrl         String?
  documentName        String?

  submittedAt         DateTime?
  responseAt          DateTime?

  notes               String?

  charCount           Int?
  wordCount           Int?
  genreMatch          Float?
  styleScore          Float?

  requirementsMet     Json?             // Stores validation results as JSON

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Index for common queries
  @@index([status])
}

model AiAnalysis {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  type                AnalysisType
  prompt              String
  response            Json

  model               String
  tokensUsed          Int
  costCents           Float

  createdAt           DateTime          @default(now())
}

model CrawlLog {
  id                  String            @id @default(cuid())
  sourceId            String
  source              Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  competitionId       String?           // Optional reference to extracted competition
  competition         Competition?      @relation(fields: [competitionId], references: [id])

  url                 String
  status              CrawlStatus

  httpCode            Int?
  errorMessage        String?
  extractedData       Json?

  processingMs        Int?

  createdAt           DateTime          @default(now())

  // Index for common queries
  @@index([sourceId, createdAt])
}

model UserFeedback {
  id                  String            @id @default(cuid())
  competitionId       String
  competition         Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  action              FeedbackAction
  reason              String?

  createdAt           DateTime          @default(now())

  // Index for common queries
  @@index([competitionId])
}

// ============================================================================
// NextAuth.js / Auth.js v5 MODELS
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
